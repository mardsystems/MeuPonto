@page
@model MeuPonto.Pages.PontoComprovantes.IndexModel

@{
    ViewData["Title"] = "Comprovantes de Ponto";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.PontoComprovante[0].Ponto)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PontoComprovante[0].Numero)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PontoComprovante[0].Imagem)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PontoComprovante[0].ImagemTipo)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PontoComprovante[0].CreationDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.PontoComprovante[0].Version)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.PontoComprovante)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Ponto.Data)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Numero)
                </td>
                <td>
                    <img src="data:image/png;base64,@Convert.ToBase64String(item.Imagem)" height="150" />
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.ImagemTipo.Nome)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.CreationDate)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Version)
                </td>
                <td>
                    <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
